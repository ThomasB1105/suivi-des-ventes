# Variables d'environnement — synchro automatique systeme.io via webhooks + base KV.
# À définir dans Vercel → Project → Settings → Environment Variables (PAS dans le code).

# Secret partagé qui protège l'endpoint de réception des webhooks.
# Mets une longue chaîne aléatoire, et reporte-la dans l'URL du webhook systeme.io :
#   https://<ton-app>.vercel.app/api/ingest?secret=CE_SECRET
INGEST_SECRET=

# Base KV (Upstash / Vercel KV). Ces deux variables sont injectées AUTOMATIQUEMENT
# quand tu connectes une base depuis Vercel → Storage. Ne les remplis à la main que
# si tu utilises Upstash directement.
KV_REST_API_URL=
KV_REST_API_TOKEN=
