# Variables d'environnement pour la synchro systeme.io.
# À définir dans Vercel → Project → Settings → Environment Variables (PAS dans le code).

# Clé API systeme.io (obligatoire) — Profil → "Public API keys" → créer une clé.
SYSTEME_API_KEY=

# Attribution organique / paid à partir des tags du contact (optionnel).
# Listes de mots-clés séparés par des virgules ; un tag qui contient l'un d'eux = ce canal.
SYSTEME_PAID_TAGS=meta,facebook,google,ads,tiktok,sea
SYSTEME_ORGANIC_TAGS=youtube,instagram,insta,seo,organic,direct
